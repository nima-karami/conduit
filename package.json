{
  "name": "conduit",
  "displayName": "Conduit",
  "description": "Agent-agnostic multi-agent terminal dashboard (standalone desktop app)",
  "version": "0.24.0",
  "author": "Nima Karami",
  "license": "MIT",
  "main": "./out/main.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "start": "npm run build && electron .",
    "rebuild": "electron-rebuild -f -w @lydell/node-pty",
    "test:unit": "vitest run",
    "test:smoke": "node test/e2e/run-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "format": "biome format --write .",
    "check": "biome check .",
    "analyze": "fallow --summary",
    "fallow:check": "fallow --skip health",
    "audit": "npm audit --audit-level=high",
    "secret-scan": "node tools/secret-scan.mjs",
    "security": "node tools/security-scan.mjs && node tools/secret-scan.mjs",
    "verify": "npm run check && npm run typecheck && npm run build && npm run test:unit && npm run fallow:check && npm run audit && npm run security",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win",
    "release": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "version": "node tools/sync-readme-version.mjs && git add README.md",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.nimakarami.conduit",
    "productName": "Conduit",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map",
      "assets/icon.*",
      "package.json",
      "!node_modules/**/*",
      "node_modules/@lydell/**/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "resources/skills",
        "to": "skills"
      }
    ],
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signtoolOptions": {
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "uninstallDisplayName": "Conduit",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-arm64-unsigned.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "publish": {
      "provider": "github",
      "owner": "nima-karami",
      "repo": "conduit"
    }
  },
  "overrides": {
    "node-gyp": {
      "undici": "^6.27.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.0",
    "fallow": "2.92.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.11.0",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "lucide-react": "^1.18.0",
    "lucide-static": "^1.18.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "pdfjs-dist": "^6.0.227",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  }
}
