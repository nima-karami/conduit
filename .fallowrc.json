{
  "$schema": "https://docs.fallow.tools/schema/config.json",
  "entry": [
    "electron/main.ts",
    "electron/preload.ts",
    "webview/index.tsx",
    "tools/*.mjs",
    "esbuild.mjs",
    "test/unit/*.test.ts",
    "test/e2e/*.mjs"
  ],
  "ignorePatterns": ["out/**", "dist/**", "designs/**", "node_modules/**"],
  "ignoreExports": [
    {
      "file": "src/protocol.ts",
      "exports": ["*"]
    },
    {
      "file": "webview/view-model.ts",
      "exports": ["*"]
    },
    {
      "file": "src/types.ts",
      "exports": ["*"]
    }
  ]
}
